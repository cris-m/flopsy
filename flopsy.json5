{
    "workspace": {},
    "gateway": {
        "host": "127.0.0.1",
        "port": 18789,
        "token": "${GATEWAY_TOKEN}",
        "rateLimit": {
            "windowMs": 60000,
            "maxRequests": 100,
            "maxConnectionsPerIp": 5
        },
        "deduplication": {
            "ttlMs": 30000,
            "maxEntries": 10000
        }
    },
    "logging": {
        "level": "debug",
        "pretty": true,
        "file": "logs/flopsy.log",
        "components": {}
    },
    "timezone": "UTC",
    "models": {},
    "mcp": {
        "enabled": true,
        "servers": {
            "obsidian": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/obsidian.ts"
                ],
                "env": {
                    "OBSIDIAN_VAULT_PATH": "/Users/munzihirwa/Documents/Obsidian Vault"
                },
                "assignTo": [
                    "gimli",
                    "legolas"
                ],
                "description": "Read/search/write an Obsidian vault"
            },
            "home-assistant": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/home-assistant.ts"
                ],
                "env": {
                    "HOME_ASSISTANT_URL": "${HOME_ASSISTANT_URL}",
                    "HOME_ASSISTANT_TOKEN": "${HOME_ASSISTANT_TOKEN}"
                },
                "requires": [
                    "HOME_ASSISTANT_URL",
                    "HOME_ASSISTANT_TOKEN"
                ],
                "assignTo": [
                    "sam"
                ],
                "description": "Smart home control: lights, climate, automations"
            },
            "virustotal": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/virustotal.ts"
                ],
                "env": {
                    "VIRUSTOTAL_API_KEY": "${VIRUSTOTAL_API_KEY}"
                },
                "requires": [
                    "VIRUSTOTAL_API_KEY"
                ],
                "assignTo": [
                    "aragorn"
                ],
                "description": "VirusTotal file, URL, IP, and domain reputation"
            },
            "shodan": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/shodan.ts"
                ],
                "env": {
                    "SHODAN_API_KEY": "${SHODAN_API_KEY}"
                },
                "requires": [
                    "SHODAN_API_KEY"
                ],
                "assignTo": [
                    "aragorn"
                ],
                "description": "Shodan network intelligence: IP lookup, device + vuln search"
            },
            "browser": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "-y",
                    "@playwright/mcp@latest",
                    "--headless"
                ],
                "assignTo": [
                    "gandalf",
                    "legolas"
                ],
                "description": "Playwright-based browser automation. Set `enabled: true` after running `npx playwright install chromium`."
            },
            "apple-notes": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/apple-notes.ts"
                ],
                "platform": "darwin",
                "assignTo": [
                    "gimli"
                ],
                "description": "Read/write Apple Notes via JXA (macOS only — needs Notes.app access permission)"
            },
            "apple-reminders": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/apple-reminders.ts"
                ],
                "platform": "darwin",
                "assignTo": [
                    "gimli"
                ],
                "description": "Apple Reminders list + item CRUD via JXA (macOS only)"
            },
            "spotify": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/spotify.ts"
                ],
                "requires": [
                    "SPOTIFY_CLIENT_ID"
                ],
                "requiresAuth": [
                    "spotify"
                ],
                "env": {
                    "SPOTIFY_CLIENT_ID": "${SPOTIFY_CLIENT_ID}"
                },
                // OAuth redirect URI for `flopsy auth spotify`. Must match
                // exactly what you register in the Spotify developer dashboard.
                "redirectBase": "http://127.0.0.1:8888/spotify",
                "assignTo": [
                    "sam"
                ],
                "description": "Spotify Web API: search, playback, devices (transfer-to), queue, playlists, library, top items. One-time setup: 1) create app at developer.spotify.com, 2) register the redirectBase URL as a Redirect URI, 3) paste Client ID into .env, 4) run `flopsy auth spotify`."
            },
            "twitter": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/twitter.ts"
                ],
                "assignTo": [
                    "aragorn"
                ],
                "description": "X/Twitter via `@steipete/bird` (cookie auth, fragile — breaks when X changes its HTML). Enable when you need it."
            },
            "gmail": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/gmail.ts"
                ],
                "requiresAuth": [
                    "google"
                ],
                "requires": [
                    "GOOGLE_CLIENT_ID",
                    "GOOGLE_CLIENT_SECRET"
                ],
                "assignTo": [
                    "legolas"
                ],
                "description": "Gmail read/search/send/draft. Needs GOOGLE_CLIENT_ID/SECRET + `flopsy auth google`, then enable."
            },
            "calendar": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/calendar.ts"
                ],
                "requiresAuth": [
                    "google"
                ],
                "requires": [
                    "GOOGLE_CLIENT_ID",
                    "GOOGLE_CLIENT_SECRET"
                ],
                "assignTo": [
                    "legolas"
                ],
                "description": "Google Calendar read/write events, find free time. Same prereqs as gmail."
            },
            "drive": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/drive.ts"
                ],
                "requiresAuth": [
                    "google"
                ],
                "requires": [
                    "GOOGLE_CLIENT_ID",
                    "GOOGLE_CLIENT_SECRET"
                ],
                "assignTo": [
                    "legolas"
                ],
                "description": "Google Drive file search + read. Same prereqs as gmail."
            },
            "youtube": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/youtube.ts"
                ],
                "requiresAuth": [
                    "google"
                ],
                "requires": [
                    "GOOGLE_CLIENT_ID",
                    "GOOGLE_CLIENT_SECRET"
                ],
                "assignTo": [
                    "legolas"
                ],
                "description": "YouTube search, video details, playlists, subscriptions. Uses YouTube Data API v3. Same Google OAuth prereqs as gmail."
            },
            "notion": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "-y",
                    "@notionhq/notion-mcp-server"
                ],
                "env": {
                    "OPENAPI_MCP_HEADERS": "{\"Authorization\":\"Bearer ${NOTION_API_KEY}\",\"Notion-Version\":\"2022-06-28\"}"
                },
                "requires": [
                    "NOTION_API_KEY"
                ],
                "assignTo": [
                    "gimli"
                ],
                "description": "Notion workspace management via the official @notionhq/notion-mcp-server"
            },
            "todoist": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "-y",
                    "@hoffination/mcp-todoist"
                ],
                "env": {
                    "TODOIST_API_TOKEN": "${TODOIST_API_KEY}"
                },
                "requires": [
                    "TODOIST_API_KEY"
                ],
                "assignTo": [
                    "gimli"
                ],
                "description": "Todoist task + project management via @hoffination/mcp-todoist"
            }
        }
    },
    "memory": {
        "enabled": true,
        "embedder": {
            "provider": "ollama",
            "model": "nomic-embed-text:v1.5"
        }
    },
    "agents": [
        {
            "name": "gandalf",
            "enabled": true,
            "type": "main",
            "role": "main",
            "workers": [
                "legolas",
                "saruman",
                "gimli",
                "aragorn",
                "sam"
            ],
            "domain": "general",
            "toolsets": [
                "research",
                "utility",
                "web",
                "finance"
            ],
            // "model": "nvidia:nvidia/nemotron-3-super-120b-a12b",
            "model": "openai:gpt-4o",
            "model_config": {
                "temperature": 0,
                "maxTokens": 4096
            },
            "fallback_models": [
                {
                    "provider": "nvidia",
                    "name": "meta/llama-3.3-70b-instruct"
                },
                {
                    "provider": "ollama",
                    "name": "gemma4:e4b"
                }
            ],
            "cost_tier": "medium",
            "routing": {
                "enabled": true,
                "tiers": {
                    "fast": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "balanced": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "powerful": {
                        "provider": "ollama",
                        "name": "qwen3-coder:480b-cloud"
                    }
                }
            }
        },
        {
            "name": "legolas",
            "enabled": true,
            "type": "research",
            "role": "worker",
            "domain": "research",
            "toolsets": [
                "research",
                "web",
                "news"
            ],
            "model": "nvidia:qwen/qwen2.5-72b-instruct",
            "model_config": {
                "temperature": 0.5
            },
            "fallback_models": [
                {
                    "provider": "nvidia",
                    "name": "meta/llama-3.3-70b-instruct"
                },
                {
                    "provider": "ollama",
                    "name": "gemma4:e4b"
                }
            ],
            "cost_tier": "medium",
            "routing": {
                "enabled": true,
                "tiers": {
                    "fast": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "balanced": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "powerful": {
                        "provider": "ollama",
                        "name": "deepseek-v3.1:671b-cloud"
                    }
                }
            }
        },
        {
            "name": "saruman",
            "enabled": true,
            "type": "deep-research",
            "role": "worker",
            "graph": "deep-research",
            "domain": "deep-research",
            "toolsets": [],
            "model": "nvidia:meta/llama-3.3-70b-instruct",
            "model_config": {
                "temperature": 0.3,
                "maxTokens": 8192
            },
            "fallback_models": [
                {
                    "provider": "nvidia",
                    "name": "qwen/qwen2.5-72b-instruct"
                },
                {
                    "provider": "ollama",
                    "name": "gemma4:e4b"
                }
            ],
            "cost_tier": "high"
        },
        {
            "name": "gimli",
            "enabled": true,
            "type": "analysis",
            "role": "worker",
            "domain": "analysis",
            "toolsets": [
                "utility",
                "filesystem"
            ],
            "model": "nvidia:meta/llama-3.1-8b-instruct",
            "model_config": {
                "temperature": 0.3,
                "maxTokens": 2048
            },
            "fallback_models": [
                {
                    "provider": "nvidia",
                    "name": "meta/llama-3.3-70b-instruct"
                },
                {
                    "provider": "ollama",
                    "name": "gemma4:e4b"
                }
            ],
            "cost_tier": "low",
            "routing": {
                "enabled": true,
                "tiers": {
                    "fast": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "balanced": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "powerful": {
                        "provider": "ollama",
                        "name": "gpt-oss:120b-cloud"
                    }
                }
            },
            "approvals": {
                "tools": [
                    "write_file",
                    "edit_file"
                ],
                "actions": [
                    "approve",
                    "skip"
                ]
            }
        },
        {
            "name": "aragorn",
            "enabled": true,
            "type": "security",
            "role": "worker",
            "domain": "security",
            "toolsets": [
                "web",
                "research"
            ],
            "mcpServers": [
                "virustotal",
                "shodan"
            ],
            "model": "nvidia:meta/llama-3.3-70b-instruct",
            "model_config": {
                "temperature": 0.2,
                "maxTokens": 4096
            },
            "fallback_models": [
                {
                    "provider": "nvidia",
                    "name": "meta/llama-3.1-8b-instruct"
                },
                {
                    "provider": "ollama",
                    "name": "gemma4:e4b"
                }
            ],
            "cost_tier": "medium",
            "routing": {
                "enabled": true,
                "tiers": {
                    "fast": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "balanced": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "powerful": {
                        "provider": "ollama",
                        "name": "gpt-oss:120b-cloud"
                    }
                }
            },
            "approvals": {
                "tools": [],
                "actions": []
            }
        },
        {
            "name": "sam",
            "enabled": true,
            "type": "media",
            "role": "worker",
            "domain": "media-and-home",
            "toolsets": [
                "utility"
            ],
            "mcpServers": [
                "spotify",
                "home-assistant"
            ],
            "model": "nvidia:meta/llama-3.1-8b-instruct",
            "model_config": {
                "temperature": 0.3,
                "maxTokens": 4096
            },
            "fallback_models": [
                {
                    "provider": "nvidia",
                    "name": "meta/llama-3.3-70b-instruct"
                },
                {
                    "provider": "ollama",
                    "name": "gemma4:e4b"
                }
            ],
            "cost_tier": "medium",
            "routing": {
                "enabled": true,
                "tiers": {
                    "fast": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "balanced": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "powerful": {
                        "provider": "ollama",
                        "name": "gpt-oss:120b-cloud"
                    }
                }
            },
            "approvals": {
                "tools": [],
                "actions": []
            }
        }
    ],
    "webhook": {
        "enabled": false,
        "port": 18790,
        "host": "127.0.0.1",
        "secret": "${WEBHOOK_SECRET}",
        "allowedIps": []
    },
    "channels": {
        "whatsapp": {
            "enabled": false,
            "sessionPath": "sessions/whatsapp",
            "dm": {
                "policy": "disabled",
                "allowFrom": [],
                "blockedFrom": []
            },
            "group": {
                "policy": "disabled",
                "activation": "mention",
                "allowedGroups": []
            },
            "selfChatMode": false,
            "sendReadReceipts": true,
            "autoTyping": true,
            "contextMessages": 100,
            "maxChunkSize": 4000,
            "media": {
                "inboundMax": 10485760,
                "outboundMax": 10485760
            },
            "ackReaction": {
                "emoji": "👀",
                "direct": true,
                "group": "mentions"
            }
        },
        "telegram": {
            "enabled": true,
            "token": "${TELEGRAM_BOT_TOKEN}",
            "botUsername": "",
            "dm": {
                "policy": "open",
                "allowFrom": [],
                "blockedFrom": []
            },
            "group": {
                "policy": "disabled",
                "activation": "mention",
                "allowedGroups": []
            },
            "ackReaction": {
                "emoji": "👀",
                "direct": true,
                "group": "mentions"
            }
        },
        "discord": {
            "enabled": true,
            "token": "${DISCORD_BOT_TOKEN}",
            "botUsername": "",
            "dm": {
                "policy": "open",
                "allowFrom": [],
                "blockedFrom": []
            },
            "guild": {
                "policy": "disabled",
                "activation": "mention",
                "allowedGuilds": [],
                "allowedChannels": []
            },
            "ackReaction": {
                "emoji": "👀",
                "direct": true,
                "group": "mentions"
            },
            "presence": {
                "status": "online",
                "activity": "Listening to messages",
                "activityType": "listening"
            },
            "slashCommands": [
                {
                    "name": "ask",
                    "description": "Ask FlopsyBot a question"
                }
            ]
        },
        "line": {
            "enabled": true,
            "channelAccessToken": "${LINE_CHANNEL_ACCESS_TOKEN}",
            "channelSecret": "${LINE_CHANNEL_SECRET}",
            "botName": "",
            "webhookPath": "/webhook/line",
            "dm": {
                "policy": "open",
                "allowFrom": [],
                "blockedFrom": []
            },
            "group": {
                "policy": "disabled",
                "activation": "mention",
                "allowedGroups": []
            }
        },
        "signal": {
            "enabled": false,
            "account": "",
            "cliPath": "signal-cli",
            "deviceName": "FlopsyBot",
            "sessionPath": "sessions/signal",
            "dm": {
                "policy": "disabled",
                "allowFrom": [],
                "blockedFrom": []
            },
            "group": {
                "policy": "disabled",
                "activation": "mention",
                "allowedGroups": []
            },
            "ackReaction": {
                "emoji": "👀",
                "direct": false,
                "group": "never"
            }
        },
        "imessage": {
            "enabled": false,
            "cliPath": "imsg",
            "selfChatMode": false,
            "dm": {
                "policy": "disabled",
                "allowFrom": [],
                "blockedFrom": []
            }
        },
        "slack": {
            "enabled": false,
            "botToken": "${SLACK_BOT_TOKEN}",
            "appToken": "${SLACK_APP_TOKEN}",
            "signingSecret": "${SLACK_SIGNING_SECRET}",
            "dm": {
                "policy": "open",
                "allowFrom": [],
                "blockedFrom": []
            },
            "group": {
                "policy": "disabled",
                "activation": "mention",
                "allowedGroups": []
            }
        },
        "googlechat": {
            "enabled": false,
            "serviceAccountKeyPath": "credentials/google-chat-sa.json",
            "verificationToken": "${GOOGLE_CHAT_VERIFICATION_TOKEN}",
            "webhookPath": "/webhook/googlechat",
            "dm": {
                "policy": "open",
                "allowFrom": [],
                "blockedFrom": []
            },
            "group": {
                "policy": "disabled",
                "activation": "mention",
                "allowedGroups": []
            }
        }
    },
    "proactive": {
        "enabled": true,
        "statePath": "state/proactive.json",
        "retryQueuePath": "state/retry-queue.json",
        "heartbeats": {
            "enabled": true,
            "heartbeats": [
                {
                    "name": "startup-ping",
                    "enabled": true,
                    "interval": "1h",
                    "prompt": "Log a startup diagnostics ping.",
                    "deliveryMode": "silent",
                    "oneshot": true
                }
            ]
        },
        "scheduler": {
            "enabled": false,
            "jobs": []
        },
        "webhooks": [],
        "healthMonitor": {
            "enabled": true,
            "checkIntervalMs": 300000,
            "staleEventThresholdMs": 600000,
            "connectGraceMs": 60000,
            "maxRestartsPerHour": 10,
            "cooldownCycles": 2
        }
    }
}
