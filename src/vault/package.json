{
  "name": "@flopsy/vault",
  "version": "1.0.0",
  "description": "Language-agnostic encrypted credential broker for AI agents. AES-256-GCM at rest, Argon2id KEK, MITM HTTPS proxy with placeholder substitution, scoped tokens with TTL + revocation, tamper-evident audit log.",
  "keywords": ["vault", "credential-broker", "ai-agent", "https-proxy", "secrets", "mitm"],
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "@noble/hashes": "^1.5.0",
    "better-sqlite3": "^11.0.0",
    "node-forge": "^1.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.3.0",
    "@types/node-forge": "^1.3.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "test": "vitest run"
  }
}
