{
    "workspace": {},
    "gateway": {
        "host": "127.0.0.1",
        "port": 18789,
        "token": "${GATEWAY_TOKEN}",
        "rateLimit": {
            "windowMs": 60000,
            "maxRequests": 100,
            "maxConnectionsPerIp": 5
        },
        "deduplication": {
            "ttlMs": 30000,
            "maxEntries": 10000
        }
    },
    "logging": {
        "level": "debug",
        "pretty": true,
        "file": "logs/flopsy.log",
        "components": {}
    },
    "timezone": "UTC",
    "models": {},
    "mcp": {
        "enabled": true,
        "servers": {
            "obsidian": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/obsidian.ts"
                ],
                "env": {
                    "OBSIDIAN_VAULT_PATH": "${OBSIDIAN_VAULT_PATH}"
                },
                "assignTo": [
                    "gimli",
                    "legolas"
                ],
                "description": "Read/search/write an Obsidian vault",
                // Large vaults with deep fuzzy search can take minutes.
                // Set to 0 to disable the timeout entirely if you still see
                // spurious timeouts (beware: a truly hung call will block
                // the agent turn indefinitely).
                "callTimeoutMs": 600000
            },
            "home-assistant": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/home-assistant.ts"
                ],
                "env": {
                    "HOME_ASSISTANT_URL": "${HOME_ASSISTANT_URL}",
                    "HOME_ASSISTANT_TOKEN": "${HOME_ASSISTANT_TOKEN}"
                },
                "requires": [
                    "HOME_ASSISTANT_URL",
                    "HOME_ASSISTANT_TOKEN"
                ],
                "assignTo": [
                    "sam"
                ],
                "description": "Smart home control: lights, climate, automations"
            },
            "virustotal": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/virustotal.ts"
                ],
                "env": {
                    "VIRUSTOTAL_API_KEY": "${VIRUSTOTAL_API_KEY}"
                },
                "requires": [
                    "VIRUSTOTAL_API_KEY"
                ],
                "assignTo": [
                    "aragorn"
                ],
                "description": "VirusTotal file, URL, IP, and domain reputation"
            },
            "shodan": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/shodan.ts"
                ],
                "env": {
                    "SHODAN_API_KEY": "${SHODAN_API_KEY}"
                },
                "requires": [
                    "SHODAN_API_KEY"
                ],
                "assignTo": [
                    "aragorn"
                ],
                "description": "Shodan network intelligence: IP lookup, device + vuln search"
            },
            "browser": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "-y",
                    "@playwright/mcp@latest",
                    "--browser",
                    "chromium",
                    "--headless"
                ],
                "assignTo": [
                    "gandalf",
                    "legolas",
                    "saruman"
                ],
                "description": "Playwright-based browser automation. Set `enabled: true` after running `npx playwright install chromium`."
            },
            "apple-notes": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/apple-notes.ts"
                ],
                "platform": "darwin",
                "assignTo": [
                    "gimli"
                ],
                "description": "Read/write Apple Notes via JXA (macOS only — needs Notes.app access permission)"
            },
            "apple-reminders": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/apple-reminders.ts"
                ],
                "platform": "darwin",
                "assignTo": [
                    "gimli"
                ],
                "description": "Apple Reminders list + item CRUD via JXA (macOS only)"
            },
            "spotify": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/spotify.ts"
                ],
                "requires": [
                    "SPOTIFY_CLIENT_ID"
                ],
                "requiresAuth": [
                    "spotify"
                ],
                "env": {
                    "SPOTIFY_CLIENT_ID": "${SPOTIFY_CLIENT_ID}"
                },
                // OAuth redirect URI for `flopsy auth spotify`. Must match
                // exactly what you register in the Spotify developer dashboard.
                "redirectBase": "http://127.0.0.1:8888/spotify",
                "assignTo": [
                    "sam"
                ],
                "description": "Spotify Web API: search, playback, devices (transfer-to), queue, playlists, library, top items. One-time setup: 1) create app at developer.spotify.com, 2) register the redirectBase URL as a Redirect URI, 3) paste Client ID into .env, 4) run `flopsy auth spotify`."
            },
            "twitter": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/twitter.ts"
                ],
                "assignTo": [
                    "aragorn"
                ],
                "description": "X/Twitter via `@steipete/bird` (cookie auth, fragile — breaks when X changes its HTML). Enable when you need it."
            },
            "gmail": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/gmail.ts"
                ],
                "requiresAuth": [
                    "google"
                ],
                "requires": [
                    "GOOGLE_CLIENT_ID",
                    "GOOGLE_CLIENT_SECRET"
                ],
                "assignTo": [
                    "legolas"
                ],
                "description": "Gmail read/search/send/draft. Needs GOOGLE_CLIENT_ID/SECRET + `flopsy auth google`, then enable."
            },
            "calendar": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/calendar.ts"
                ],
                "requiresAuth": [
                    "google"
                ],
                "requires": [
                    "GOOGLE_CLIENT_ID",
                    "GOOGLE_CLIENT_SECRET"
                ],
                "assignTo": [
                    "legolas"
                ],
                "description": "Google Calendar read/write events, find free time. Same prereqs as gmail."
            },
            "drive": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/drive.ts"
                ],
                "requiresAuth": [
                    "google"
                ],
                "requires": [
                    "GOOGLE_CLIENT_ID",
                    "GOOGLE_CLIENT_SECRET"
                ],
                "assignTo": [
                    "legolas"
                ],
                "description": "Google Drive file search + read. Same prereqs as gmail.",
                "callTimeoutMs": 300000
            },
            "youtube": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "tsx",
                    "${MCP_ROOT}/youtube.ts"
                ],
                "requiresAuth": [
                    "google"
                ],
                "requires": [
                    "GOOGLE_CLIENT_ID",
                    "GOOGLE_CLIENT_SECRET"
                ],
                "assignTo": [
                    "legolas"
                ],
                "description": "YouTube search, video details, playlists, subscriptions. Uses YouTube Data API v3. Same Google OAuth prereqs as gmail."
            },
            "notion": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "-y",
                    "@notionhq/notion-mcp-server"
                ],
                "env": {
                    "OPENAPI_MCP_HEADERS": "{\"Authorization\":\"Bearer ${NOTION_API_KEY}\",\"Notion-Version\":\"2022-06-28\"}"
                },
                "requires": [
                    "NOTION_API_KEY"
                ],
                "assignTo": [
                    "gimli"
                ],
                "description": "Notion workspace management via the official @notionhq/notion-mcp-server"
            },
            "todoist": {
                "enabled": true,
                "transport": "stdio",
                "command": "npx",
                "args": [
                    "-y",
                    "@hoffination/mcp-todoist"
                ],
                "env": {
                    "TODOIST_API_TOKEN": "${TODOIST_API_KEY}"
                },
                "requires": [
                    "TODOIST_API_KEY"
                ],
                "assignTo": [
                    "gimli"
                ],
                "description": "Todoist task + project management via @hoffination/mcp-todoist"
            }
        }
    },
    "memory": {
        "enabled": true,
        "embedder": {
            "provider": "ollama",
            "model": "nomic-embed-text:v1.5"
        }
    },
    "agents": [
        {
            "name": "gandalf",
            "enabled": true,
            "type": "main",
            "role": "main",
            "workers": [
                "legolas",
                "saruman",
                "gimli",
                "aragorn",
                "sam"
            ],
            "domain": "general",
            "toolsets": [
                "research",
                "utility",
                "web",
                "finance"
            ],
            // Default voice overlay applied when no per-turn override and no
            // session-set /personality value exists. Must match a key in
            // .flopsy/personalities.yaml. Uncomment to start sessions in a
            // specific voice instead of plain SOUL.md. Per-session
            // /personality choices still win over this default.
            // "defaultPersonality": "concise",
            // 70B is fast enough to compose post-delegation replies (worker brief
            // + conversation + 33 tools) inside the 45s modelCallTimeoutMs.
            // The 675B mistral was timing out every turn — kept as last-ditch
            // fallback for hard problems where 70B might struggle, but only
            // after the local gemma so we don't waste 45s by default.
            //"model": "nvidia:meta/llama-3.3-70b-instruct",
            "model": "openai:gpt-5.4",  // fastest paid option
            "model_config": {
                "temperature": 0,
                "maxTokens": 4096
            },
            "fallback_models": [
                {
                    "provider": "ollama",
                    "name": "gemma4:e4b"
                },
                {
                    "provider": "nvidia",
                    "name": "mistralai/mistral-large-3-675b-instruct-2512"
                }
            ],
            "cost_tier": "medium",
            "routing": {
                "enabled": true,
                "tiers": {
                    "fast": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "balanced": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "powerful": {
                        "provider": "ollama",
                        "name": "qwen3-coder:480b-cloud"
                    }
                }
            },
            // Sandbox — gives gandalf `execute_code` (foreground + background).
            // Programmatic tool calling lets the model pass `use_tools: true`
            // so its code can call status/tasks/team/doctor/MCP tools as
            // functions and only print the summary, saving thousands of tokens
            // on multi-tool queries.
            //
            // backend: "local" | "docker" | "kubernetes" | <custom-name>.
            // Custom names work after calling registerSandboxBackend(name, ...)
            // at boot — see flopsygraph's sandbox docs.
            //
            // Production checklist (multi-tenant or LLM-vs-adversarial-user):
            //   1. backend = "docker" (or "kubernetes")
            //   2. untrusted = true   — refuses local backend; forces isolation
            //   3. hardened  = true   — adds custom seccomp profile + metadata-IP block
            //   4. image     = pinned digest (e.g. "python:3.12-slim@sha256:...")
            //                  prevents supply-chain attacks via tag re-pointing
            "sandbox": {
                "enabled": true,
                "backend": "docker",
                "language": "python",
                "timeout": 120000,  // 2 min default; per-call override up to 600000 (10 min)
                "programmaticToolCalling": true,
                // Tier-2 hardening: seccomp profile blocking unshare/bpf/ptrace/
                // mount/kernel-module/reboot syscalls, plus 169.254.169.254 cloud
                // metadata IP block on top of the Tier-1 defaults (CapDrop ALL,
                // no-new-privileges, read-only rootfs, non-root user, PidsLimit).
                "hardened": true,
                // Refuse the local backend entirely — forces docker/k8s isolation
                // for any LLM-generated code. Pair with backend="docker".
                "untrusted": true
                // Pin the container image by digest for supply-chain integrity.
                // Tag-only pulls (e.g. "python:3.12-slim") trust Docker Hub to
                // not re-point the tag — fine for dev, NOT for production.
                // Example:
                //   "image": "python:3.12-slim@sha256:0123456789abcdef..."
            }
        },
        {
            "name": "legolas",
            "enabled": true,
            "type": "research",
            "role": "worker",
            "domain": "research",
            "toolsets": [
                "research",
                "web",
                "news"
            ],
            "model": "nvidia:qwen/qwen2.5-72b-instruct",
            "model_config": {
                "temperature": 0.5
            },
            "fallback_models": [
                {
                    "provider": "nvidia",
                    "name": "meta/llama-3.3-70b-instruct"
                },
                {
                    "provider": "ollama",
                    "name": "gemma4:e4b"
                }
            ],
            "cost_tier": "medium",
            "routing": {
                "enabled": true,
                "tiers": {
                    "fast": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "balanced": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "powerful": {
                        "provider": "ollama",
                        "name": "deepseek-v3.1:671b-cloud"
                    }
                }
            }
        },
        {
            "name": "saruman",
            "enabled": true,
            "type": "deep-research",
            "role": "worker",
            "graph": "deep-research",
            "domain": "deep-research",
            "toolsets": ["research", "web", "news"],
            "model": "nvidia:meta/llama-3.3-70b-instruct",
            "model_config": {
                "temperature": 0.3,
                "maxTokens": 8192
            },
            "fallback_models": [
                {
                    "provider": "nvidia",
                    "name": "qwen/qwen2.5-72b-instruct"
                },
                {
                    "provider": "ollama",
                    "name": "gemma4:e4b"
                }
            ],
            "cost_tier": "high",
            // Tier-based routing for the deep-research pipeline.
            //   fast      → query expansion + cheap pre-filter steps
            //   balanced  → most research stages (default working model)
            //   powerful  → final synthesis where token + reasoning quality matter
            // The deep-research graph doesn't pick tiers per-stage today —
            // the router is built so workers can opt in when they want.
            "routing": {
                "enabled": true,
                "tiers": {
                    "fast": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "balanced": {
                        "provider": "nvidia",
                        "name": "meta/llama-3.3-70b-instruct"
                    },
                    "powerful": {
                        "provider": "nvidia",
                        "name": "qwen/qwen2.5-72b-instruct"
                    }
                }
            }
        },
        {
            "name": "gimli",
            "enabled": true,
            "type": "analysis",
            "role": "worker",
            "domain": "analysis",
            "toolsets": [
                "utility",
                "filesystem"
            ],
            "model": "nvidia:meta/llama-3.1-8b-instruct",
            "model_config": {
                "temperature": 0.3,
                "maxTokens": 2048
            },
            "fallback_models": [
                {
                    "provider": "nvidia",
                    "name": "meta/llama-3.3-70b-instruct"
                },
                {
                    "provider": "ollama",
                    "name": "gemma4:e4b"
                }
            ],
            "cost_tier": "low",
            "routing": {
                "enabled": true,
                "tiers": {
                    "fast": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "balanced": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "powerful": {
                        "provider": "ollama",
                        "name": "gpt-oss:120b-cloud"
                    }
                }
            },
            "approvals": {
                "tools": [
                    "write_file",
                    "edit_file"
                ],
                "actions": [
                    "approve",
                    "skip"
                ]
            }
        },
        {
            "name": "aragorn",
            "enabled": true,
            "type": "security",
            "role": "worker",
            "domain": "security",
            "toolsets": [
                "web",
                "research"
            ],
            "mcpServers": [
                "virustotal",
                "shodan"
            ],
            "model": "nvidia:meta/llama-3.3-70b-instruct",
            "model_config": {
                "temperature": 0.2,
                "maxTokens": 4096
            },
            "fallback_models": [
                {
                    "provider": "nvidia",
                    "name": "meta/llama-3.1-8b-instruct"
                },
                {
                    "provider": "ollama",
                    "name": "gemma4:e4b"
                }
            ],
            "cost_tier": "medium",
            "routing": {
                "enabled": true,
                "tiers": {
                    "fast": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "balanced": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "powerful": {
                        "provider": "ollama",
                        "name": "gpt-oss:120b-cloud"
                    }
                }
            },
            "approvals": {
                "tools": [],
                "actions": []
            }
        },
        {
            "name": "sam",
            "enabled": true,
            "type": "media",
            "role": "worker",
            "domain": "media-and-home",
            "toolsets": [
                "utility"
            ],
            "mcpServers": [
                "spotify",
                "home-assistant"
            ],
            "model": "nvidia:meta/llama-3.1-8b-instruct",
            "model_config": {
                "temperature": 0.3,
                "maxTokens": 4096
            },
            "fallback_models": [
                {
                    "provider": "nvidia",
                    "name": "meta/llama-3.3-70b-instruct"
                },
                {
                    "provider": "ollama",
                    "name": "gemma4:e4b"
                }
            ],
            "cost_tier": "medium",
            "routing": {
                "enabled": true,
                "tiers": {
                    "fast": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "balanced": {
                        "provider": "ollama",
                        "name": "gemma4:e4b"
                    },
                    "powerful": {
                        "provider": "ollama",
                        "name": "gpt-oss:120b-cloud"
                    }
                }
            },
            "approvals": {
                "tools": [],
                "actions": []
            }
        }
    ],
    "webhook": {
        "enabled": false,
        "port": 18790,
        "host": "127.0.0.1",
        "secret": "${WEBHOOK_SECRET}",
        "allowedIps": []
    },
    "channels": {
        "whatsapp": {
            "enabled": false,
            "sessionPath": "sessions/whatsapp",
            "dm": {
                "policy": "disabled",
                "allowFrom": [],
                "blockedFrom": []
            },
            "group": {
                "policy": "disabled",
                "activation": "mention",
                "allowedGroups": []
            },
            "selfChatMode": false,
            "sendReadReceipts": true,
            "autoTyping": true,
            "contextMessages": 100,
            "maxChunkSize": 4000,
            "media": {
                "inboundMax": 10485760,
                "outboundMax": 10485760
            },
            "ackReaction": {
                "emoji": "👀",
                "direct": true,
                "group": "mentions"
            }
        },
        "telegram": {
            "enabled": true,
            "token": "${TELEGRAM_BOT_TOKEN}",
            "botUsername": "",
            "dm": {
                "policy": "pairing",
                "allowFrom": [],
                "blockedFrom": []
            },
            "group": {
                "policy": "disabled",
                "activation": "mention",
                "allowedGroups": []
            },
            "ackReaction": {
                "emoji": "👀",
                "direct": true,
                "group": "mentions"
            }
        },
        "discord": {
            "enabled": true,
            "token": "${DISCORD_BOT_TOKEN}",
            "botUsername": "",
            "dm": {
                "policy": "open",
                "allowFrom": [],
                "blockedFrom": []
            },
            "guild": {
                "policy": "disabled",
                "activation": "mention",
                "allowedGuilds": [],
                "allowedChannels": []
            },
            "ackReaction": {
                "emoji": "👀",
                "direct": true,
                "group": "mentions"
            },
            "presence": {
                "status": "online",
                "activity": "Listening to messages",
                "activityType": "listening"
            },
            "slashCommands": [
                {
                    "name": "ask",
                    "description": "Ask FlopsyBot a question"
                }
            ]
        },
        "line": {
            "enabled": true,
            "channelAccessToken": "${LINE_CHANNEL_ACCESS_TOKEN}",
            "channelSecret": "${LINE_CHANNEL_SECRET}",
            "botName": "",
            "webhookPath": "/webhook/line",
            "dm": {
                "policy": "open",
                "allowFrom": [],
                "blockedFrom": []
            },
            "group": {
                "policy": "disabled",
                "activation": "mention",
                "allowedGroups": []
            }
        },
        "signal": {
            "enabled": false,
            "account": "",
            "cliPath": "signal-cli",
            "deviceName": "FlopsyBot",
            "sessionPath": "sessions/signal",
            "dm": {
                "policy": "disabled",
                "allowFrom": [],
                "blockedFrom": []
            },
            "group": {
                "policy": "disabled",
                "activation": "mention",
                "allowedGroups": []
            },
            "ackReaction": {
                "emoji": "👀",
                "direct": false,
                "group": "never"
            }
        },
        "imessage": {
            "enabled": false,
            "cliPath": "imsg",
            "selfChatMode": false,
            "dm": {
                "policy": "disabled",
                "allowFrom": [],
                "blockedFrom": []
            }
        },
        "slack": {
            "enabled": false,
            "botToken": "${SLACK_BOT_TOKEN}",
            "appToken": "${SLACK_APP_TOKEN}",
            "signingSecret": "${SLACK_SIGNING_SECRET}",
            "dm": {
                "policy": "open",
                "allowFrom": [],
                "blockedFrom": []
            },
            "group": {
                "policy": "disabled",
                "activation": "mention",
                "allowedGroups": []
            }
        },
        "googlechat": {
            "enabled": false,
            "serviceAccountKeyPath": "credentials/google-chat-sa.json",
            "verificationToken": "${GOOGLE_CHAT_VERIFICATION_TOKEN}",
            "webhookPath": "/webhook/googlechat",
            "dm": {
                "policy": "open",
                "allowFrom": [],
                "blockedFrom": []
            },
            "group": {
                "policy": "disabled",
                "activation": "mention",
                "allowedGroups": []
            }
        }
    },
    "proactive": {
        // Master switch for heartbeats / cron / webhooks.
        // Schedules live in <workspace>/state/proactive.db — manage via
        // `flopsy schedule ...` or by asking the agent.
        "enabled": true,

        // followActiveChannel routes proactive messages to wherever the
        // user last chatted. The static `delivery` below is the fallback
        // when no recent peer is known (e.g. after a fresh restart).
        "followActiveChannel": true,
        "delivery": {
            "channelName": "telegram",
            "peer": { "id": "YOUR_CHAT_ID", "type": "user" }
        },

        "heartbeats": { "enabled": true },
        "scheduler":  { "enabled": true },
        "webhooks": [],

        "healthMonitor": {
            "enabled": true,
            "checkIntervalMs": 300000,
            "staleEventThresholdMs": 600000,
            "connectGraceMs": 60000,
            "maxRestartsPerHour": 10,
            "cooldownCycles": 2
        }
    }
}
