# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FlopsyBot Environment Variables
# Copy to .env and fill in your values
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Workspace ─────────────────────────────────────────────
# Set to . to use the project root, or an absolute path, or leave unset for ~/.flopsy
FLOPSY_HOME=.flopsy

# ── Gateway ────────────────────────────────────────────────
GATEWAY_TOKEN=

# ── LLM Providers ─────────────────────────────────────────
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# NVIDIA_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=

# ── Channels ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ── Webhook ───────────────────────────────────────────────
WEBHOOK_SECRET=
